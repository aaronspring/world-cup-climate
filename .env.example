# Copy to .env (gitignored) or export in your shell.

# Arraylake API token (starts with ema_). Required for live data.
# Get one at https://app.earthmover.io  ->  Settings -> API tokens.
ARRAYLAKE_TOKEN=ema_xxxxxxxxxxxxxxxxxxxx

# Data source: "live" (Arraylake) or "fake" (synthetic, no token needed).
WCC_DATA_SOURCE=fake

# ERA5 access path: "edr" (Flux EDR, recommended) or "xarray" (Python client).
WCC_ERA5_VIA=edr

# Optional: pin "today" for reproducible demos (otherwise the system date).
# WCC_TODAY=2026-06-15

# Optional server bind
# WCC_HOST=127.0.0.1
# WCC_PORT=8000
